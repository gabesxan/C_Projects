# Editor settings
.vscode/
**/.vscode/

# macOS
.DS_Store

# Build outputs (compilados)
*.out
*.o
*.exe

# Backend web: saida de build (binarios + bancos de teste) e banco gerado
src/backend/web/build/
src/backend/web/public/
src/backend/data/*.db
# Binarios de anexos enviados em runtime (metadados ficam no banco).
src/backend/data/anexos/
# Certificados TLS de desenvolvimento (gerados por `make cert`).
src/backend/web/certs/

# Distribuicao gerada por `make release`.
executavel/bin/
executavel/frontend/
.claude/
